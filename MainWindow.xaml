<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Design"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes" x:Class="Design.MainWindow"
        Style="{StaticResource MaterialDesignWindow}"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800" WindowStyle="ThreeDBorderWindow">

    <!-- DRAWERHOST состоит из двух слоев, менюшка выдвигается за окно влево -->
    <materialDesign:DrawerHost x:Name="MainDrawer" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">

        <!-- ВЫДВИЖНОЕ ОКНО -->
        <materialDesign:DrawerHost.LeftDrawerContent>
            <StackPanel Width="220" Background="#FF383642">
                <TextBlock Text="Главное меню" Margin="20" FontWeight="Bold" HorizontalAlignment="Center" />
                <Button Content="Хнопка Раз" Margin="10" Background="#FF3E2961"/>
                <Button Content="Хнопка Двас" Margin="10" Background="#FF3E2961"/>
            </StackPanel>
        </materialDesign:DrawerHost.LeftDrawerContent>


        <!-- ОСНОВНОЕ ОКНО -->
        <Grid Background="#FF4D4C52">
            <!-- КНОПКА ДЛЯ ОТКРЫТИЯ МЕНЮ -->
            <ToggleButton x:Name="MenuToggleButton" 
                      IsChecked="{Binding ElementName=MainDrawer, Path=IsLeftDrawerOpen}"
                      Style="{StaticResource MaterialDesignHamburgerToggleButton}"
                      HorizontalAlignment="Left" VerticalAlignment="Top" Margin="15">
                <materialDesign:PackIcon Kind="ArrowRight" />
            </ToggleButton>

            <TextBlock Text="ЗДЕСЬ БУДЕТ ГЛАВНОЕ МЕНЮ ЛАУНЧЕРА" HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Grid>
    </materialDesign:DrawerHost>


</Window>
    