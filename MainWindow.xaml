<Window x:Class="SmartLauncher_Filemanager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SmartLauncher_Filemanager"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Style="{StaticResource MaterialDesignWindow}"
        mc:Ignorable="d"
        Title="Smart Launcher" Height="450" Width="800" WindowStyle="ThreeDBorderWindow">

    <!-- Инициализируем DialogHost для всплывающего окна редактирования -->
    <materialDesign:DialogHost x:Name="EditDialogHost" Identifier="RootDialog">
        <!-- Внутреннее окно редактирования (показывается программно) -->
        <materialDesign:DialogHost.DialogContent>
            <StackPanel Margin="20" Width="300" Background="#FF383642">
                <TextBlock Text="Редактирование элемента" Foreground="White" FontWeight="Bold" Margin="0,0,0,15" HorizontalAlignment="Center"/>

                <!-- Поле изменения имени -->
                <TextBox x:Name="EditNameTextBox" 
                         materialDesign:HintAssist.Hint="Название приложения" 
                         Foreground="White" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0,0,0,15"/>

                <!-- Выбор новой иконки -->
                <Button Content="Выбрать другую иконку" Click="ChangeIcon_Click" Margin="0,0,0,20" Background="#FF3E2961" BorderBrush="{x:Null}"/>

                <!-- Кнопки сохранения/отмены -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Отмена" Click="CancelEdit_Click" Style="{StaticResource MaterialDesignFlatButton}" Margin="0,0,10,0"/>
                    <Button Content="Сохранить" Click="SaveEdit_Click" Style="{StaticResource MaterialDesignRaisedButton}" Background="#FF463E54"/>
                </StackPanel>
            </StackPanel>
        </materialDesign:DialogHost.DialogContent>

        <!-- Вся ваша основная разметка теперь внутри DialogHost -->
        <materialDesign:DrawerHost x:Name="MainDrawer" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <!-- ВЫДВИЖНОЕ ОКНО -->
            <materialDesign:DrawerHost.LeftDrawerContent>
                <StackPanel Width="220" Background="#FF383642">
                    <TextBlock Text="Главное меню" Margin="20" FontWeight="Bold" HorizontalAlignment="Center" Foreground="White"/>
                    <Button Content="Кнопка Раз" Margin="10" Background="#FF3E2961"/>

                    <!-- БЛОК ПЛЕЕРА ВМЕСТО КНОПКИ ДВАC -->
                    <Border Background="#FF2A2834" Margin="10" Padding="10" CornerRadius="8">
                        <StackPanel>
                            <TextBlock Text="Музыкальный плеер" Foreground="White" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,10"/>

                            <!-- Название текущего трека -->
                            <TextBlock x:Name="TrackNameTextBlock" Text="Файл не выбран" Foreground="#FFA0A0A0" FontSize="11" TextAlignment="Center" TextWrapping="Wrap" Margin="0,0,0,10"/>

                            <!-- Кнопки управления -->
                            <UniformGrid Columns="3">
                                <Button Content="📁" Click="OpenAudio_Click" ToolTip="Открыть файл" Background="#FF3E2961" BorderBrush="{x:Null}" Padding="0" Margin="2"/>
                                <Button x:Name="PlayPauseButton" Content="▶" Click="PlayPause_Click" ToolTip="Воспроизведение/Пауза" Background="#FF3E2961" BorderBrush="{x:Null}" Padding="0" Margin="2"/>
                                <Button Content="⏹" Click="StopAudio_Click" ToolTip="Стоп" Background="#FF3E2961" BorderBrush="{x:Null}" Padding="0" Margin="2"/>
                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <!-- Сам элемент воспроизведения (скрытый, так как нам нужен только звук) -->
                    <MediaElement x:Name="AudioPlayer" LoadedBehavior="Manual" UnloadedBehavior="Stop" Visibility="Collapsed"/>
                </StackPanel>
            </materialDesign:DrawerHost.LeftDrawerContent>


            <!-- ОСНОВНОЕ ОКНО -->
            <Grid Background="#FF4D4C52">
                <!-- КНОПКА ДЛЯ ОТКРЫТИЯ МЕНЮ -->
                <ToggleButton x:Name="MenuToggleButton" 
                              IsChecked="{Binding ElementName=MainDrawer, Path=IsLeftDrawerOpen}"
                              Style="{StaticResource MaterialDesignHamburgerToggleButton}"
                              HorizontalAlignment="Left" VerticalAlignment="Top" Margin="15">
                    <materialDesign:PackIcon Kind="Menu" />
                </ToggleButton>

                <!-- ЦЕНТРАЛЬНЫЙ СПИСОК И КНОПКА -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ListBox x:Name="FilesListBox" 
                             MouseDoubleClick="FilesListBox_MouseDoubleClick" 
                             Width="650" Height="300" Margin="10" 
                             Background="#FF463E54" Foreground="White"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" IsItemsHost="True" />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>

                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <materialDesign:Card Width="120" Height="140" Margin="5" Background="#FF3E2961" UniformCornerRadius="5">
                                    <!-- ДОБАВЛЕНО: Контекстное меню для каждой плитки -->
                                    <materialDesign:Card.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Редактировать" Click="EditMenuItem_Click"/>
                                        </ContextMenu>
                                    </materialDesign:Card.ContextMenu>

                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <!-- Иконка из файла -->
                                        <Image Source="{Binding Icon}" Width="48" Height="48" Margin="0,10,0,5" RenderOptions.BitmapScalingMode="HighQuality">
                                            <Image.Style>
                                                <Style TargetType="Image">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Icon}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Image.Style>
                                        </Image>

                                        <!-- Заглушка -->
                                        <materialDesign:PackIcon Kind="Application" Width="40" Height="40" HorizontalAlignment="Center" Margin="0,10,0,5">
                                            <materialDesign:PackIcon.Style>
                                                <Style TargetType="materialDesign:PackIcon">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Icon}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </materialDesign:PackIcon.Style>
                                        </materialDesign:PackIcon>

                                        <TextBlock Text="{Binding Name}" 
                                                   TextAlignment="Center" 
                                                   FontSize="12" 
                                                   FontWeight="SemiBold"
                                                   Foreground="White"
                                                   TextWrapping="Wrap" 
                                                   Margin="5" 
                                                   MaxHeight="40"/>
                                    </StackPanel>
                                </materialDesign:Card>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Button Content="Добавить файл" Click="AddFile_Click" Margin="10" 
                            Style="{StaticResource MaterialDesignRaisedButton}" 
                            Background="#FF463E54" BorderBrush="#FF352F40" />
                </StackPanel>
            </Grid>
        </materialDesign:DrawerHost>
    </materialDesign:DialogHost>
</Window>